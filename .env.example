# ── LINE Messaging API (จาก LINE Developers Console > Messaging API) ──
LINE_CHANNEL_ACCESS_TOKEN=ใส่_channel_access_token_ที่นี่
LINE_CHANNEL_SECRET=ใส่_channel_secret_ที่นี่
# userId ของแอดมินที่จะรับแชท/ออเดอร์ (ดูวิธีหาใน README.md)
LINE_ADMIN_USER_ID=ใส่_admin_userId_ที่นี่

# ── PromptPay (สำหรับสร้าง QR รับเงิน) ──
# ใส่เบอร์พร้อมเพย์ (0812345678) หรือเลขบัตรประชาชน 13 หลัก
PROMPTPAY_ID=0812345678
PROMPTPAY_NAME=VAYU Store

# ── Stripe (สำหรับจ่ายด้วยบัตรเครดิต/เดบิต) ──
# จาก https://dashboard.stripe.com/apikeys (ใช้ test key ขึ้นต้น sk_test_ ได้)
STRIPE_SECRET_KEY=sk_test_xxxxxxxx
# (ไม่บังคับ) สำหรับ production — ตั้ง webhook ที่ /webhook/stripe แล้วเอา secret มาใส่
STRIPE_WEBHOOK_SECRET=

# (ไม่บังคับ) URL สาธารณะของเว็บ เช่น https://xxxx.ngrok-free.app
# ใช้สร้างลิงก์ success/cancel ของ Stripe ถ้าไม่ตั้งจะ derive จาก request เอง
PUBLIC_URL=

# พอร์ตของเซิร์ฟเวอร์
PORT=3000

# ── Database Provider ──
# sqlite = ใช้ฐานข้อมูลเดิมในเครื่อง
# supabase = เตรียมสลับไปใช้ Supabase/Postgres
DB_PROVIDER=sqlite

# ── Supabase ──
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key
# สำหรับงานย้ายข้อมูล/ฝั่งเซิร์ฟเวอร์ แนะนำให้ใส่ service role key หรือ secret key ของฝั่ง server
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── LINE OA bridge (เชื่อม Live Chat เว็บ <-> LINE OA ผ่าน lineoa_bot) ──
# ต้องตรงกับ WEB_API_CLIENT_ID / WEB_API_SECRET ในไฟล์ lineoa_bot/.env
LINEOA_API_BASE_URL=https://your-lineoa-bot-host
LINEOA_API_CLIENT_ID=website-primary
LINEOA_API_SECRET=your-strong-shared-secret
# header names (ไม่ต้องแก้ถ้าใช้ค่าเริ่มต้น)
LINEOA_API_CLIENT_HEADER_NAME=X-LineOA-Client
LINEOA_API_SECRET_HEADER_NAME=X-LineOA-Secret
